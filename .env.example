# ═══════════════════════════════════════════════
#  ABT Yordamchi Bot — .env sozlamalari
# ═══════════════════════════════════════════════

SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── DATABASE (SQLite — PostgreSQL shart emas) ──
USE_SQLITE=true
USE_MEMORY_CACHE=true
CELERY_EAGER=true

# ── TELEGRAM BOT ───────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── AI (Groq — BEPUL!) ────────────────────────
# 1. https://console.groq.com ga kiring
# 2. API Keys → Create API Key
# 3. gsk_... key ni shu yerga kiriting
GROQ_API_KEY=

GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI (ixtiyoriy, pullik) ─────────────────
OPENAI_API_KEY=

# ── TO'LOV (ixtiyoriy) ─────────────────────────
STRIPE_SECRET_KEY=
CLICK_SERVICE_ID=
PAYME_MERCHANT_ID=
